import numpy as np
import matplotlib.pyplot as plt
from sklearn.linear_model import LogisticRegression

# Dataset
x = np.array([[1], [2], [3], [4], [5], [6]])
y = np.array([0, 0, 0, 1, 1, 1])

# Train model
model = LogisticRegression(solver='liblinear')
model.fit(x, y)

# Prediction
hours = 3.5
prediction = model.predict([[hours]])
probability = model.predict_proba([[hours]])[0]

print("Study Hours:", hours)
print("Prediction (0=Fail, 1=Pass):", prediction[0])
print("Probability [Fail, Pass]:", probability)

# Generate curve
x_test = np.linspace(0, 7, 100).reshape(-1, 1)
y_prob = model.predict_proba(x_test)[:, 1]

# ===============================
# GRAPH 1: Logistic Curve
# ===============================
plt.figure(figsize=(8,5))
plt.scatter(x, y, color='red', label="Actual Data")
plt.plot(x_test, y_prob, color='blue', label="Logistic Curve")
plt.axhline(0.5, color='green', linestyle='--', label="Decision Boundary")
plt.xlabel("Study Hours")
plt.ylabel("Probability of Passing")
plt.title("Logistic Regression Curve")
plt.legend()
plt.grid()
plt.show()

# ===============================
# GRAPH 2: Decision Regions
# ===============================
plt.figure(figsize=(8,5))

# Color regions
for i in range(len(x_test)):
    if y_prob[i] >= 0.5:
        plt.scatter(x_test[i], y_prob[i], color='lightgreen', s=10)
    else:
        plt.scatter(x_test[i], y_prob[i], color='lightcoral', s=10)

plt.scatter(x, y, color='black', label="Actual Data")
plt.xlabel("Study Hours")
plt.ylabel("Probability")
plt.title("Decision Region Visualization")
plt.legend()
plt.grid()
plt.show()

# ===============================
# GRAPH 3: Prediction Probability Bar Chart
# ===============================
labels = ['Fail', 'Pass']
plt.figure(figsize=(6,4))
plt.bar(labels, probability, color=['red', 'green'])

plt.title(f"Prediction Probability for {hours} Hours")
plt.ylabel("Probability")
plt.ylim(0,1)

for i, v in enumerate(probability):
    plt.text(i, v + 0.02, f"{v:.2f}", ha='center')

plt.show()
